# ─────────────────────────────────────────────────────────────────────────────
# School Management System — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on (Render sets this automatically)
PORT=3001

# Node environment: "development" or "production"
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Render app URL, e.g.:
#   ALLOWED_ORIGINS=https://your-app-name.onrender.com
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to backend/)
# Leave as default unless you move the file.
DB_PATH=./school.db
